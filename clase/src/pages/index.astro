---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Methodology from '../components/Methodology.astro';
import AboutMe from '../components/AboutMe.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Clases Particulares de Programación">

	<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none opacity-30 bg-[#fbf9f4]">
		<svg class="absolute top-0 left-0 w-full h-[400px]" preserveAspectRatio="none" viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg">
			<path fill="#f97316" d="M0,160L48,170.7C96,181,192,203,288,186.7C384,171,480,117,576,106.7C672,96,768,128,864,154.7C960,181,1056,203,1152,181.3C1248,160,1344,96,1392,64L1440,32L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path>
		</svg>
		<svg class="absolute bottom-0 left-0 w-full h-[400px] opacity-60" preserveAspectRatio="none" viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg">
			<path fill="#fbbf24" fill-opacity="1" d="M0,256L60,229.3C120,203,240,149,360,144C480,139,600,181,720,202.7C840,224,960,224,1080,202.7C1200,181,1320,139,1380,117.3L1440,96L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"></path>
		</svg>
		<div class="absolute top-1/4 left-1/4 w-[700px] h-[700px] bg-orange-400 rounded-full blur-[140px] opacity-20"></div>
		<div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-yellow-400 rounded-full blur-[100px] opacity-20"></div>
	</div>

	<main class="relative z-10 w-full flex flex-col items-center px-4 sm:px-6">
		<Hero />
		<Methodology />
		<AboutMe />
	</main>

	<Footer />

</Layout>