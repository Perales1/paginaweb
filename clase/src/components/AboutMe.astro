---
// src/components/AboutMe.astro
---
<section id="sobre-mi" class="w-full max-w-4xl mt-16 mb-40 mx-auto px-6 relative z-10 scroll-mt-24">

    <div class="flex items-center gap-4 mb-6 opacity-0 translate-y-4 transition-all duration-700" id="about-header">
        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix&backgroundColor=ffedd5" alt="Tu Avatar" class="w-16 h-16 rounded-full border-2 border-orange-400 bg-white shadow-lg" />
        <div>
            <h3 class="text-2xl font-black text-slate-900">Hola, soy tu futuro profe 👋</h3>
            <p class="text-orange-500 font-bold text-sm" id="typing-status">Escribiendo mensaje...</p>
        </div>
    </div>

    <div class="relative ml-4 sm:ml-8">
        <span class="absolute -top-12 -left-10 text-[8rem] text-orange-300/30 font-serif leading-none select-none -z-10">"</span>

        <p id="typewriter-text" class="inline text-xl sm:text-2xl font-medium text-slate-800 leading-relaxed border-l-4 border-orange-400 pl-6"></p>

        <span id="cursor" class="inline-block w-3 h-6 bg-orange-500 align-middle ml-1 hidden cursor-blink"></span>
    </div>
</section>

<style>
    @keyframes blink { 50% { opacity: 0; } }
    .cursor-blink { animation: blink 0.8s step-end infinite; }
</style>

<script>
    // ESTE ES EL TEXTO QUE SE VA A ESCRIBIR SOLO. ¡Cámbialo por lo que quieras!
    const textToType = "Llevo años picando código y peleándome con bugs para que tú no tengas que hacerlo. Mi objetivo no es soltarte un rollo teórico, sino enseñarte a pensar como un desarrollador real. Si quieres aprender creando proyectos que molen y sin perder el tiempo, estás en el lugar correcto. ¿Le damos caña?";

    const el = document.getElementById('typewriter-text');
    const cursor = document.getElementById('cursor');
    const header = document.getElementById('about-header');
    const status = document.getElementById('typing-status');

    let isTyping = false;

    const typeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            // Cuando la sección entra en pantalla y no ha empezado a escribir...
            if(entry.isIntersecting && !isTyping) {
                isTyping = true;

                // Mostramos el avatar
                header.classList.remove('opacity-0', 'translate-y-4');
                cursor.classList.remove('hidden');

                let i = 0;
                function typeNextChar() {
                    if (i < textToType.length) {
                        el.textContent += textToType.charAt(i);
                        i++;
                        // Velocidad aleatoria en cada pulsación (entre 20ms y 60ms) para dar realismo
                        const speed = Math.random() * 40 + 20;
                        setTimeout(typeNextChar, speed);
                    } else {
                        // Ha terminado de escribir
                        status.textContent = "Mensaje enviado justo ahora";
                        status.classList.replace('text-orange-500', 'text-slate-400');
                    }
                }
                // Retraso de medio segundo antes de empezar a escribir para que de tiempo a leer
                setTimeout(typeNextChar, 600);
            }
        });
    }, { threshold: 0.5 }); // Arranca cuando el 50% de la sección es visible

    const aboutSection = document.getElementById('sobre-mi');
    if (aboutSection) typeObserver.observe(aboutSection);
</script>
