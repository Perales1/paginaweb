---
interface Props {
    title: string;
    body: string;
    href: string;
    step: string;
}

const { href, title, body, step } = Astro.props;
---

<li class="group list-none rounded-2xl bg-white p-8 border border-slate-100 shadow-md shadow-slate-100/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-orange-500/5 hover:border-orange-200">
    <a href={href} class="no-underline block">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-orange-50 text-orange-600 font-bold text-sm transition-colors duration-300 group-hover:bg-amber-100 group-hover:text-amber-700">
            {step}
        </div>
        <h3 class="m-0 text-xl font-bold text-slate-900 transition-colors duration-200 group-hover:text-orange-600">
            {title}
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1 text-orange-400">&rarr;</span>
        </h3>
        <p class="mt-3 mb-0 text-slate-600 leading-relaxed text-sm">
            {body}
        </p>
    </a>
</li>